  NDASent
  NDASigned
  DataRoomAccess
  Meeting
  Call
  Email
  Feedback
  TermSheet
  Note
  Other
}

// Provenance: who/what created a record (AI-native pattern, à la Twenty's ACTOR type).
enum ActorSource {
