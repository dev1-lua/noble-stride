// NobleStride Capital CRM — data model
// Ported from the validated Twenty prototype (NOBLESTRIDE-CRM-SPEC.md §3/§4).
// 6 core objects + Person (contacts), User (team), Activity (interaction log), Task.

generator client {
  provider = "prisma-client-js"
}

// Pothos reads this to type the GraphQL schema from Prisma models (see src/graphql/builder.ts).
generator pothos {
  provider = "prisma-pothos-types"
  output   = "../src/generated/pothos-types.ts"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Controlled vocabularies (SPEC §4). Display labels are mapped in src/lib/vocab.ts.
// ─────────────────────────────────────────────────────────────────────────────

enum Sector {
  Agribusiness
  FinancialServices
  FMCG
  Manufacturing
  RenewableEnergy
  Technology
  Healthcare
  Banking
  RealEstate
  Education
  Infrastructure
  Aviation
  Construction
  Hospitality
  Leasing
  MediaEntertainment
  Services
  TransportLogistics
  WaterSanitation
  Energy
  OilAndGas
  Mining
  Gambling
  Alcohol
  Tobacco
}

enum Priority {
  High
  Medium
  Low
}

enum PartnerFeeStatus {
  NotDue
  Due
  Invoiced
  Paid
}

enum InvestorType {
  PrivateEquity
  VentureCapital
  DFI
  DebtProvider
  FamilyOffice
  Angel
  CorporateVC
  GrantDonor
  Corporate
  Individual
}

enum InvestorStatus {
  ActivelyDeploying
  Fundraising
  FinalClose
  FullyDeployed
  Dormant
}

enum Instrument {
  Equity
  Debt
  Mezzanine
  Grant
  Convertible
  Hybrid
}

enum InvestmentStage {
  PreSeed
  Seed
  SeriesA
  SeriesB
  Growth
  MatureBuyout
}

enum Geography {
  EastAfrica
  WestAfrica
  SouthernAfrica
  SubSaharanAfrica
  PanAfrica
  NorthAfrica
  FrancophoneAfrica
  MENA
  Europe
  USA
  Global
}

enum MandateStage {
  NewLead
  Qualification
  PitchPresentation
  Proposal
  Negotiation
  Signed
  Lost
}

enum TransactionStage {
  DealPreparation
  InvestorOutreach
  DueDiligence
  TermSheet
  Closing
  ClosedWon
  ClosedLost
}

enum EngagementStatus {
  NotContacted
  Contacted
  InConversation
  Interested
  Passed
  Committed
}

enum Source {
  MondayMeeting
  WhatsApp
  Email
  Verbal
  Referral
  Inbound
  Outreach
  Event
  Website
  DirectEnquiry
  Consultant
  Investor
  Partner
  SocialMedia
  InternalBusinessDev
  Other
}

enum DocStatus {
  NotSent
  Sent
  Signed
}

enum DealType {
  SeriesA
  SeriesB
  Growth
  Expansion
  AcquisitionFinance
}

enum PartnerType {
  LawFirm
  Auditor
  Advisor
  Bank
  InvestmentBank
  Consulting
  Other
}

enum PartnerStatus {
  Active
  Preferred
  Inactive
}

enum FounderGender {
  Male
  Female
  Mixed
}

enum TaskStatus {
  NotStarted
  Pending
  Ongoing
  Done
  Dropped
}

// Engagement-tracker interaction types (wireframe stat cards + timeline).
enum InteractionType {
  Outreach
  NDASent
  NDASigned
  DataRoomAccess
  Meeting
  Call
  Email
  Feedback
  TermSheet
  Note
  Other
}

// Provenance: who/what created a record (AI-native pattern, à la Twenty's ACTOR type).
enum ActorSource {
  HUMAN
  AGENT
  API
  IMPORT
  SYSTEM
}

enum EngagementStage {
  Shared
  TeaserSent
  NDASigned
  IMShared
  VDRAccess
  Meeting
  InfoRequest
  DueDiligence
  TermSheet
  Offer
  Invested
  Declined
}

enum InterestLevel {
  Low
  Medium
  High
}

enum NdaType {
  Open
  Closed
}

enum DisbursementStatus {
  Disbursed
  Ongoing
  FellOff
  Dropped
}

enum InvestorEngagementClassification {
  Active
  Inactive
  OnHold
  Excluded
  Greylisted
}

enum InvestorNdaStatus {
  None
  OpenNDA
  ClosedNDA
}

enum OnboardingStatus {
  PendingReview
  Approved
  Rejected
}

enum BlockedRegistrationKind {
  Domain
  Email
}

enum AdvisorType {
  Lawyer
  Investor
  Consultant
  TransactionAdvisor
  AdvisoryFirm
  Other
}

enum ServiceProviderType {
  LawFirm
  Audit
  Tax
  ESG
  Technical
  Other
}

enum DocumentType {
  NDA
  EngagementContract
  FeeShareAgreement
  Teaser
  IM
  FinancialModel
  Valuation
  PitchDeck
  AuditedAccounts
  CR12
  TermSheet
  LoanAgreement
  SPA
  SHA
  BusinessPlan
  Other
}

enum DocumentAccessLevel {
  Internal
  ClientShared
  InvestorShared
  VDR
}

enum DocumentStatus {
  Draft
  UnderReview
  Approved
  Shared
  Executed
}

enum PartnerAgreementStatus {
  None
  Sent
  Signed
}

// CAK / COMESA competition-approval lifecycle (SPEC §3.2)
enum RegulatoryStatus {
  NotStarted
  Filed
  Approved
  NotRequired
}

// §6.2 due-diligence workstreams
enum DDTrack {
  Financial
  Tax
  Commercial
  ESG
  Legal
}

enum DDStatus {
  NotStarted
  InProgress
  Complete
  Flagged
  NotApplicable
}

// §7.2 in-org roles (demo lens, not auth)
enum OrgRole {
  Admin
  DealLead
  TeamMember
}

// "Sectors and Milestones" doc — fixed milestones for investors (14 steps + post-deal).
enum MilestoneKey {
  TeaserReview // Receipt and review of the teaser
  NdaExecuted // Execution of the NDA
  ExpressionOfInterest // EOI / LOI / email confirming interest
  DataRoomAccess
  PreliminaryDD // desktop due diligence
  ICPaperPrepared // internal IC paper
  FirstICApproval
  NonBindingTermSheet
  TermSheetExecuted
  OnsiteDD // financial / tax / commercial / ESG / legal
  SecondICApproval
  BindingOffer
  DefinitiveAgreements // loan agreement or SPA/SHA
  CompetitionApproval // CAK / COMESA notification
  SuccessFeePaid // post-deal
}

// ─────────────────────────────────────────────────────────────────────────────
// Spec-gap enums (SPEC §3.1/§3.10/§4.x) — deal financing/status/milestone,
// max selling stake, task source, communication channel/direction, client
// status, impact flags.
// ─────────────────────────────────────────────────────────────────────────────

enum DealFinancingType {
  Debt
  Equity
  EquityAndDebt
}

enum DealStatus {
  Open
  OnHold
  Closed
  ClosedReopened
  ClosedOnHold
  Dropped
}

enum DealMilestone {
  TermSheet
  NonBindingOffer
  LoanAgreement
  SpaSha
  DueDiligence
  IC
  TA
  Closed
}

enum MaxSellingStake {
  Minority
  Majority
  FullSale
  NA
}

enum TaskSource {
  MondayMeeting
  WhatsApp
  Email
  Verbal
  Other
}

enum CommChannel {
  WhatsApp
  Email
  Slack
  WebChat
  Call
  Meeting
}

enum CommDirection {
  Inbound
  Outbound
}

enum ClientStatus {
  Active
  Prospect
  Archived
}

enum ImpactFlag {
  WomenLed
  YouthLed
}

enum Profitability {
  Profitable
  LossMaking
}

// ─────────────────────────────────────────────────────────────────────────────
// Team & contacts
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  jobTitle    String?
  avatarColor String? // hex for the avatar chip
  isActive    Boolean  @default(true)
  role        OrgRole  @default(Admin) // §7.2 in-org role (demo lens)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ledMandates       Mandate[]     @relation("MandateLead")
  ownedTransactions Transaction[] @relation("TransactionOwner")
  ownedEngagements  Engagement[]  @relation("EngagementOwner")
  ddTracks          DueDiligenceTrack[] @relation("DDTrackOwner")
  activities        Activity[]    @relation("ActivityCreatedBy")
  assignedTasks     Task[]        @relation("TaskAssignee")
  documents         Document[]    @relation("DocumentUploadedBy")
  reviewedDocuments Document[]    @relation("DocumentReviewer")
  approvedDocuments Document[]    @relation("DocumentApprover")
  assistantTransactions Transaction[] @relation("TransactionAssistant")
  assistantTasks        Task[]        @relation("TaskAssistant")
  stageChanges          StageChange[] @relation("StageChangeActor")
  savedViews   SavedView[] @relation("SavedViewCreatedBy")
  notifications Notification[]
  authAccount AuthAccount?
}

model Person {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String?
  email       String?
  phone       String?
  jobTitle    String?
  linkedinUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  isPrimaryContact Boolean   @default(false)
  isSSAContact     Boolean   @default(false)

  investorId String?
  investor   Investor? @relation(fields: [investorId], references: [id], onDelete: SetNull)
  clientId   String?
  client     Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  partnerId  String?
  partner    Partner?  @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  ssaForInvestors Investor[] @relation("InvestorSsaContact")
  authAccount AuthAccount?

  @@index([investorId])
  @@index([clientId])
  @@index([partnerId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Investor — the fund database (SPEC §3.1)
// ─────────────────────────────────────────────────────────────────────────────

model Investor {
  id                  String          @id @default(cuid())
  name                String
  investorType        InvestorType
  website             String?
  status              InvestorStatus?
  sectorFocus         Sector[]        @default([])
  geographicFocus     Geography[]     @default([])
  instruments         Instrument[]    @default([])
  investmentStages    InvestmentStage[] @default([])
  aum                 Decimal?        @db.Decimal(20, 2)
  ticketMin           Decimal?        @db.Decimal(20, 2)
  ticketMax           Decimal?        @db.Decimal(20, 2)
  currency            String          @default("USD")
  targetIrr           Float?
  countryRestrictions String?
  esgFocus            String?
  decisionProcess     String? // rich text / markdown
  notes               String?
  // Task 5: engagement classification, NDA status, profile fields
  engagementClassification InvestorEngagementClassification @default(Active)
  ndaStatus                InvestorNdaStatus                @default(None)
  // Investor onboarding (design spec 2026-07-05): approval gate + demo-OTP stamps + open-NDA record
  onboardingStatus         OnboardingStatus                 @default(Approved)
  emailVerifiedAt          DateTime?
  phoneVerifiedAt          DateTime?
  registeredAt             DateTime?
  openNdaSignedAt          DateTime?
  shareholdingPreference   String?
  minRevenue               Decimal?  @db.Decimal(20, 2)
  minEbitda                Decimal?  @db.Decimal(20, 2)
  minLoanBook              Decimal?  @db.Decimal(20, 2)
  pricingPreference        String?
  remainingInvestmentPeriod String?
  ddRequirements           String?
  icApprovalProcess        String?
  trackRecord              String?
  investmentMandate        String?
  nextActionDate           DateTime?
  feedback                 String?
  // "Data collected from potential investors" doc §3–§7 (fund self-service profile)
  notableInvestments   String? // §3 deals closed, exits achieved
  portfolioComposition String? // §3 sector, size, performance
  caseStudies          String? // §3 deals similar to the NobleStride pipeline
  reinvestmentPolicy   String? // §4
  teamComposition      String? // §6 key personnel for deal evaluation
  collaborationTerms   String? // §6 NDA, exclusivity
  impactMetrics        String? // §7 social/environmental outcomes prioritized
  reputationalRisks    String? // §7 controversial sectors or geographies
  ssaRegionContactId       String?
  ssaRegionContact         Person?   @relation("InvestorSsaContact", fields: [ssaRegionContactId], references: [id], onDelete: SetNull)
  // Task 6: criteria verification stamp
  criteriaVerifiedAt  DateTime?
  createdSource       ActorSource     @default(HUMAN)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  contacts    Person[]
  engagements Engagement[]
  activities  Activity[]
  tasks       Task[]
  documents   Document[]
  stageChanges StageChange[]
  blockedRegistrations BlockedRegistration[]

  @@index([investorType])
  @@index([status])
  @@index([engagementClassification])
  @@index([onboardingStatus])
}

// BlockedRegistration — email domains/addresses barred from self-registration.
// Populated when an investor is greylisted (anti-broker guardrail): corporate
// domains block the whole domain; free-provider addresses block the exact email.
model BlockedRegistration {
  id         String                  @id @default(cuid())
  kind       BlockedRegistrationKind
  value      String // normalized lower-case: domain ("acme.com") or full email
  reason     String?
  investorId String?
  investor   Investor?               @relation(fields: [investorId], references: [id], onDelete: SetNull)
  createdAt  DateTime                @default(now())

  @@unique([kind, value])
  @@index([investorId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Client — the company raising capital (SPEC §3.2)
// ─────────────────────────────────────────────────────────────────────────────

model Client {
  id                String         @id @default(cuid())
  name              String
  yearFounded       Int?
  hqCity            String?
  countries         Geography[]    @default([])
  website           String?
  sector            Sector[]       @default([])
  coreProduct       String?
  description       String?
  founders          String?
  founderGenders    FounderGender[] @default([])
  revenueLastYear   Decimal?       @db.Decimal(20, 2)
  revenueForecast   Decimal?       @db.Decimal(20, 2)
  currency          String         @default("USD")
  profitability     Profitability?
  existingInvestors String?
  source            Source?
  pitchDeckUrl      String?
  // Spec-gap: company profile fields (spec §3.1/§3.2)
  codename             String? // project codename, kept separate from legal name
  registrationNo       String?
  hqCountry            String?
  businessModel        String?
  foundersNationality  String?
  ownershipStructure   String?
  directorsManagement  String?
  targetClients        String?
  staffCount           Int?
  branchCount          Int?
  ebitda               Decimal?     @db.Decimal(20, 2)
  netProfit            Decimal?     @db.Decimal(20, 2)
  existingDebt         Decimal?     @db.Decimal(20, 2)
  loanBook             Decimal?     @db.Decimal(20, 2)
  totalAssets          Decimal?     @db.Decimal(20, 2)
  impactFlags          ImpactFlag[] @default([])
  status               ClientStatus @default(Prospect)
  // Task 6: qualification/scoping gap fields
  pepExposure            Boolean  @default(false)
  governmentOwned        Boolean  @default(false)
  complianceNotes        String?
  auditedFinancialsYears Int?
  groupStructure         String?
  suppliers              String?
  competitors            String?
  capacityUtilization    String?
  repaymentAbilityNotes  String?
  pricingExpectations    String?
  proposedTimeline       String?
  createdSource     ActorSource    @default(HUMAN)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  contacts     Person[]
  mandates     Mandate[]
  transactions Transaction[]
  tasks        Task[]
  documents    Document[]
  activities   Activity[]
  stageChanges StageChange[]

  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Mandate — client-acquisition pipeline (Kanban by stage) (SPEC §3.3)
// ─────────────────────────────────────────────────────────────────────────────

model Mandate {
  id             String       @id @default(cuid())
  name           String
  stage          MandateStage @default(NewLead)
  stageEnteredAt DateTime     @default(now()) // drives "days in stage"
  dealStatus     DealStatus   @default(Open)
  dealSize       Decimal?     @db.Decimal(20, 2)
  currency       String       @default("USD")
  sector         Sector[]     @default([])
  source         Source?
  dateOpened     DateTime?
  ndaStatus      DocStatus    @default(NotSent)
  ndaSentDate    DateTime?
  ndaSignedDate  DateTime?
  eaStatus       DocStatus    @default(NotSent)
  eaSentDate     DateTime?
  eaSignedDate   DateTime?
  nextAction     String?
  notes          String?
  // Task 6: retainer + qualification fields
  retainerAmount       Decimal?  @db.Decimal(20, 2)
  retainerInvoicedDate DateTime?
  retainerPaidDate     DateTime?
  priority             Priority?
  referralQualified    Boolean?
  qualificationVerdict String?
  qualificationReasons String[]
  qualifiedAt          DateTime?
  createdSource  ActorSource  @default(HUMAN)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  clientId     String
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  leadId       String?
  lead         User?         @relation("MandateLead", fields: [leadId], references: [id], onDelete: SetNull)
  referredById String?
  referredBy   Partner?      @relation("PartnerReferral", fields: [referredById], references: [id], onDelete: SetNull)
  transactions Transaction[]
  activities   Activity[]
  tasks        Task[]
  documents    Document[]
  stageChanges StageChange[]

  @@index([stage])
  @@index([clientId])
  @@index([leadId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Transaction — fundraising-execution pipeline (Kanban by stage) (SPEC §3.4)
// ─────────────────────────────────────────────────────────────────────────────

model Transaction {
  id             String           @id @default(cuid())
  name           String
  stage          TransactionStage @default(DealPreparation)
  stageEnteredAt DateTime         @default(now())
  dealType       DealType?
  instrument     Instrument[]     @default([])
  targetRaise    Decimal?         @db.Decimal(20, 2)
  currency       String           @default("USD")
  sector         Sector[]         @default([])
  dateOpened     DateTime?
  closedAt       DateTime? // set when stage -> ClosedWon/ClosedLost; drives avg-time-to-close
  // Success fee (workflow doc Stage 4): invoiced on close per the engagement contract
  successFeeAmount       Decimal?  @db.Decimal(20, 2)
  successFeeInvoicedDate DateTime?
  successFeePaidDate     DateTime?
  // Spec-gap: deal status/milestone/financing fields (spec §4.1/§4.3/§4.5/§4.7)
  dealStatus      DealStatus         @default(Open)
  dealMilestone   DealMilestone?
  financingType   DealFinancingType?
  maxSellingStake MaxSellingStake?
  targetProfile   String?
  useOfFunds      String?
  vdrLink         String?
  probability     Int?
  notes           String?
  // §3.2 IC approvals + CAK/COMESA regulatory tracking (deal-level, internal-only)
  icFirstApprovalDate   DateTime?
  icSecondApprovalDate  DateTime?
  cakComesaStatus       RegulatoryStatus @default(NotStarted)
  cakComesaFiledDate    DateTime?
  cakComesaApprovedDate DateTime?
  // Task 6: priority + partner fee tracking
  priority          Priority?
  partnerFeeStatus  PartnerFeeStatus?
  partnerFeeAmount  Decimal?           @db.Decimal(20, 2)
  createdSource  ActorSource      @default(HUMAN)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  clientId    String
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  mandateId   String?
  mandate     Mandate?     @relation(fields: [mandateId], references: [id], onDelete: SetNull)
  ownerId     String?
  owner       User?        @relation("TransactionOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  assistantId String?
  assistant   User?        @relation("TransactionAssistant", fields: [assistantId], references: [id], onDelete: SetNull)
  referredById String?
  referredBy   Partner?    @relation("PartnerTransactionReferral", fields: [referredById], references: [id], onDelete: SetNull)
  engagements      Engagement[]
  activities       Activity[]
  tasks            Task[]
  serviceProviders ServiceProvider[] @relation("TransactionServiceProviders")
  documents        Document[]
  stageChanges     StageChange[]
  ddTracks         DueDiligenceTrack[]

  @@index([stage])
  @@index([clientId])
  @@index([ownerId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Engagement — join: one investor approached on one transaction (SPEC §3.5)
// ─────────────────────────────────────────────────────────────────────────────

model Engagement {
  id            String           @id @default(cuid())
  name          String
  status        EngagementStatus @default(NotContacted)
  lastContact   DateTime?
  notes         String?
  createdSource ActorSource      @default(HUMAN)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  engagementStage    EngagementStage     @default(Shared)
  interestLevel      InterestLevel?
  ndaType            NdaType?
  ndaSignedAt        DateTime?
  termSheetIssued    Boolean             @default(false)
  termSheetDate      DateTime?
  totalAmount        Decimal?            @db.Decimal(20, 2)
  amountDisbursed    Decimal?            @db.Decimal(20, 2)
  amountPending      Decimal?            @db.Decimal(20, 2)
  disbursementStatus DisbursementStatus?
  dateReceived       DateTime?
  year               Int?
  quarter            Int?
  probability        Int?
  feedback           String?

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  investorId    String
  investor      Investor    @relation(fields: [investorId], references: [id], onDelete: Cascade)
  ownerId       String?
  owner         User?       @relation("EngagementOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  activities    Activity[]
  milestones    EngagementMilestone[]
  stageChanges  StageChange[]

  @@unique([transactionId, investorId])
  @@index([status])
  @@index([investorId])
  @@index([engagementStage])
}

// ─────────────────────────────────────────────────────────────────────────────
// EngagementMilestone — the fixed investor milestone checklist per engagement
// ("Sectors and Milestones" doc). A row exists when a milestone is reached.
// ─────────────────────────────────────────────────────────────────────────────

model EngagementMilestone {
  id           String       @id @default(cuid())
  engagementId String
  engagement   Engagement   @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  key          MilestoneKey
  completedAt  DateTime     @default(now())
  notes        String?
  createdSource ActorSource @default(HUMAN)

  @@unique([engagementId, key])
  @@index([engagementId])
}

// ─────────────────────────────────────────────────────────────────────────────
// DueDiligenceTrack — deal-level DD workstreams (SPEC §6.2): financial / tax /
// commercial / ESG / legal. INTERNAL ONLY — never projected to the portal.
// ─────────────────────────────────────────────────────────────────────────────

model DueDiligenceTrack {
  id          String    @id @default(cuid())
  track       DDTrack
  status      DDStatus  @default(NotStarted)
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  transactionId     String
  transaction       Transaction      @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  ownerId           String?
  owner             User?            @relation("DDTrackOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  serviceProviderId String?
  serviceProvider   ServiceProvider? @relation("DDTrackProvider", fields: [serviceProviderId], references: [id], onDelete: SetNull)

  @@unique([transactionId, track])
  @@index([transactionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Partner — service providers & referral sources (SPEC §3.6)
// ─────────────────────────────────────────────────────────────────────────────

model Partner {
  id          String        @id @default(cuid())
  name        String
  partnerType PartnerType?
  profile     String?
  status      PartnerStatus @default(Active)
  location    String?
  amount      Decimal?      @db.Decimal(20, 2)
  currency               String                 @default("USD")
  // Task 6: advisor type, fee-sharing, partner agreement, internal-only, direct contact
  advisorType            AdvisorType?
  organization           String?
  email                  String?
  phone                  String?
  feeSharingAgreement    Boolean                @default(false)
  feeSharingTerms        String?
  partnerAgreementStatus PartnerAgreementStatus @default(None)
  internalOnly           Boolean                @default(true)
  // Task 6: feedback notes
  feedbackNotes          String?
  createdSource ActorSource   @default(HUMAN)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  contacts         Person[]
  referredMandates Mandate[] @relation("PartnerReferral")
  referredTransactions Transaction[] @relation("PartnerTransactionReferral")
  stageChanges     StageChange[]
  documents            Document[]

  @@index([partnerType])
  @@index([status])
  @@index([advisorType])
}

// ─────────────────────────────────────────────────────────────────────────────
// Activity — interaction log powering the Engagement tracker timeline & counters
// ─────────────────────────────────────────────────────────────────────────────

model Activity {
  id            String          @id @default(cuid())
  type          InteractionType
  subject       String?
  body          String?
  occurredAt    DateTime        @default(now())
  createdSource ActorSource     @default(HUMAN)
  createdAt     DateTime        @default(now())
  // Spec-gap: communication channel/direction (spec §3.10)
  channel       CommChannel?
  direction     CommDirection?

  engagementId  String?
  engagement    Engagement?  @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  investorId    String?
  investor      Investor?    @relation(fields: [investorId], references: [id], onDelete: SetNull)
  mandateId     String?
  mandate       Mandate?     @relation(fields: [mandateId], references: [id], onDelete: SetNull)
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdById   String?
  createdBy     User?        @relation("ActivityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  tasks         Task[]       @relation("ActivityTasks")

  @@index([type])
  @@index([engagementId])
  @@index([occurredAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Task — lightweight activities reused across records (SPEC §3.7)
// ─────────────────────────────────────────────────────────────────────────────

model Task {
  id        String     @id @default(cuid())
  title     String
  status    TaskStatus @default(NotStarted)
  dueAt     DateTime?
  body      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  // Spec-gap: source of the task + escalation flag (spec §3.10/§4.12)
  source    TaskSource?
  escalated Boolean     @default(false)

  assigneeId    String?
  assignee      User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  mandateId     String?
  mandate       Mandate?     @relation(fields: [mandateId], references: [id], onDelete: SetNull)
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  investorId    String?
  investor      Investor?    @relation(fields: [investorId], references: [id], onDelete: SetNull)
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assistantId   String?
  assistant     User?        @relation("TaskAssistant", fields: [assistantId], references: [id], onDelete: SetNull)
  activityId    String?
  activity      Activity?    @relation("ActivityTasks", fields: [activityId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([assigneeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ServiceProvider — transaction-level service providers (SPEC §3.7)
// ─────────────────────────────────────────────────────────────────────────────

model ServiceProvider {
  id            String              @id @default(cuid())
  name          String
  type          ServiceProviderType
  contactPerson String?
  email         String?
  phone         String?
  profile       String?
  fee           Decimal?            @db.Decimal(20, 2)
  currency      String              @default("USD")
  status        String?
  createdSource ActorSource         @default(HUMAN)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  engagedOn     Transaction[]       @relation("TransactionServiceProviders")
  ddTracks      DueDiligenceTrack[] @relation("DDTrackProvider")

  @@index([type])
}

// ─────────────────────────────────────────────────────────────────────────────
// Document — metadata + file link (SPEC §3.8)
// Binary storage handled externally; this model tracks metadata + access level.
// ─────────────────────────────────────────────────────────────────────────────

model Document {
  id            String              @id @default(cuid())
  name          String
  type          DocumentType
  version       String?
  accessLevel   DocumentAccessLevel @default(Internal)
  status        DocumentStatus?
  fileUrl       String?
  uploadedById  String?
  uploadedBy    User?               @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  uploadedAt    DateTime            @default(now())
  // Review chain (workflow doc Stage 2): peer review -> MD approval -> client review
  reviewerId       String?
  reviewer         User?     @relation("DocumentReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewedAt       DateTime?
  approverId       String?
  approver         User?     @relation("DocumentApprover", fields: [approverId], references: [id], onDelete: SetNull)
  approvedAt       DateTime?
  clientReviewedAt DateTime?
  transactionId String?
  transaction   Transaction?        @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  clientId      String?
  client        Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  investorId    String?
  investor      Investor?           @relation(fields: [investorId], references: [id], onDelete: SetNull)
  mandateId     String?
  mandate       Mandate?            @relation(fields: [mandateId], references: [id], onDelete: SetNull)
  partnerId     String?
  partner       Partner?            @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  createdSource ActorSource         @default(HUMAN)
  createdAt     DateTime            @default(now())

  @@index([type])
  @@index([accessLevel])
  @@index([transactionId])
  @@index([mandateId])
}

// ─────────────────────────────────────────────────────────────────────────────
// StageChange — append-only stage/status change history (SPEC §7.1).
// Never updated or deleted; a new row is written on every stage/status move.
// ─────────────────────────────────────────────────────────────────────────────

model StageChange {
  id            String       @id @default(cuid())
  field         String       // "stage" | "dealStatus" | "engagementStage" | "dealMilestone" | "name" | "registrationNo" | "primaryContact"
  fromValue     String?
  toValue       String
  changedAt     DateTime     @default(now())
  changedById   String?
  changedBy     User?        @relation("StageChangeActor", fields: [changedById], references: [id], onDelete: SetNull)
  createdSource ActorSource  @default(HUMAN)
  mandateId     String?
  mandate       Mandate?     @relation(fields: [mandateId], references: [id], onDelete: Cascade)
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  engagementId  String?
  engagement    Engagement?  @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  investorId    String?
  investor      Investor?    @relation(fields: [investorId], references: [id], onDelete: Cascade)
  partnerId     String?
  partner       Partner?     @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([mandateId])
  @@index([transactionId])
  @@index([engagementId])
  @@index([clientId])
  @@index([investorId])
  @@index([partnerId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SavedView — team-shared queue views (name + serialized filter/sort/columns).
// ─────────────────────────────────────────────────────────────────────────────

model SavedView {
  id          String   @id @default(cuid())
  name        String
  entity      String   @default("deals") // future-proof; only "deals" today
  config      Json     // { filters, sort, dir, columns, groupBy, view }
  createdById String?
  createdBy   User?    @relation("SavedViewCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([entity])
}

// ─────────────────────────────────────────────────────────────────────────────
// Notification — per-user notification feed (Task 6 gap closure).
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

// Real authentication (design spec 2026-07-08): credentials + DB sessions.
// AuthAccount links to User (internal staff) or Person (investor contact).
// ─────────────────────────────────────────────────────────────────────────────

enum AccountKind {
  INTERNAL
  INVESTOR
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum AuthTokenPurpose {
  RESET_PASSWORD
  VERIFY_EMAIL
}

enum AuthOtpPurpose {
  LOGIN_2FA
}

model AuthAccount {
  id           String        @id @default(cuid())
  email        String        @unique // always stored lowercase
  passwordHash String
  kind         AccountKind
  status       AccountStatus @default(PENDING)
  // Pre-approval signup details for internal accounts not yet in the directory:
  displayName  String?
  jobTitle     String?
  userId       String?       @unique
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  personId     String?       @unique
  person       Person?       @relation(fields: [personId], references: [id], onDelete: Cascade)
  failedLogins Int           @default(0)
  lockedUntil  DateTime?
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  sessions      AuthSession[]
  tokens        AuthToken[]
  otpChallenges AuthOtpChallenge[]

  @@index([kind, status])
}

model AuthSession {
  id         String      @id @default(cuid())
  tokenHash  String      @unique // sha256 hex of the opaque token; raw token never stored
  accountId  String
  account    AuthAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime    @default(now())
  lastUsedAt DateTime    @default(now())
  ip         String?
  userAgent  String?

  @@index([accountId])
}

model AuthToken {
  id        String           @id @default(cuid())
  tokenHash String           @unique
  accountId String
  account   AuthAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  purpose   AuthTokenPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([accountId])
}

model AuthOtpChallenge {
  id          String         @id @default(cuid())
  accountId   String
  account     AuthAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  purpose     AuthOtpPurpose
  codeHash    String // sha256 hex of the 6-digit code; raw code never stored
  destination String // email the code was actually sent to (audit)
  attempts    Int            @default(0)
  maxAttempts Int            @default(5)
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime       @default(now())

  @@index([accountId, purpose])
}
