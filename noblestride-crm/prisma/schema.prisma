  WhatsApp
  Email
  Verbal
  Referral
  Inbound
  Outreach
  Event
  Website
  DirectEnquiry
  Consultant
  Investor
  Partner
  SocialMedia
  InternalBusinessDev
  Other
}

enum DocStatus {
  NotSent
  Sent
  Signed
}

enum DealType {
  SeriesA
  SeriesB
  Growth
  Expansion
  AcquisitionFinance
}

enum PartnerType {
  LawFirm
  Auditor
  Advisor
  Bank
  InvestmentBank
  Consulting
  Other
}

enum PartnerStatus {
  Active
  Preferred
  Inactive
}

enum FounderGender {
  Male
  Female
  Mixed
}

enum TaskStatus {
  NotStarted
  Pending
  Ongoing
  Done
  Dropped
}

// Engagement-tracker interaction types (wireframe stat cards + timeline).
enum InteractionType {
