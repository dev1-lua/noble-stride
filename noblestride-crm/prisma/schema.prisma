// Noblestride Capital CRM — data model
// Ported from the validated Twenty prototype (NOBLESTRIDE-CRM-SPEC.md §3/§4).
// 6 core objects + Person (contacts), User (team), Activity (interaction log), Task.

generator client {
  provider = "prisma-client-js"
}

// Pothos reads this to type the GraphQL schema from Prisma models (see src/graphql/builder.ts).
generator pothos {
  provider = "prisma-pothos-types"
  output   = "../src/generated/pothos-types.ts"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Controlled vocabularies (SPEC §4). Display labels are mapped in src/lib/vocab.ts.
// ─────────────────────────────────────────────────────────────────────────────

